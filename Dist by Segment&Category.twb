      <column caption='Other ' datatype='string' name='[Calculation_1280979000541184]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt;= 45000 THEN ATTR([Sub-Category])&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg.order' datatype='real' name='[Calculation_1280979312361473]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])/COUNTD([Order ID])' />
      </column>
      <column caption='summary' datatype='real' name='[Calculation_1280979315617794]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt; 45000 THEN SUM([Sales])&#13;&#10;ELSE WINDOW_SUM(IF SUM([Sales]) &lt;= 45000 THEN SUM([Sales]) END)&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='others2' datatype='string' name='[Calculation_1280979321532421]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sub-Category] IN [Big Sub-Categories] THEN [Sub-Category]&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
